// CALCUL VOLUME
window.calculateVolume = function(pumpId) {
  const pompe = DISTRIBUTEURS.find(p => p.id === pumpId);
  if (!pompe) return;
  const debutElec = debutIndex.elec[pumpId] || 0;
  const debutMec = debutIndex.mec[pumpId] || 0;
  const finElecStr = document.getElementById(`fin_elec_${pumpId}`)?.value.trim();
  const finMecStr = document.getElementById(`fin_mec_${pumpId}`)?.value.trim();
  const ecartStr = document.getElementById(`ecart_${pumpId}`)?.value.trim() || '';
  
  let finElec = null, finMec = null, volElec = 0, volMec = 0, ca = 0;
  
  const inputElec = document.getElementById(`fin_elec_${pumpId}`);
  const inputMec = document.getElementById(`fin_mec_${pumpId}`);
  
  if (finElecStr !== '') {
    finElec = parseFloat(finElecStr);
    if (!isNaN(finElec) && finElec >= debutElec) { inputElec.classList.add('valid'); inputElec.classList.remove('error'); volElec = finElec - debutElec; }
    else if (!isNaN(finElec) && finElec < debutElec) { inputElec.classList.add('error'); inputElec.classList.remove('valid'); }
    else { inputElec.classList.add('error'); inputElec.classList.remove('valid'); }
  } else { inputElec?.classList.remove('error', 'valid'); }
  
  if (finMecStr !== '') {
    finMec = parseFloat(finMecStr);
    if (!isNaN(finMec) && finMec >= debutMec) { inputMec.classList.add('valid'); inputMec.classList.remove('error'); volMec = finMec - debutMec; }
    else if (!isNaN(finMec) && finMec < debutMec) { inputMec.classList.add('error'); inputMec.classList.remove('valid'); }
    else { inputMec.classList.add('error'); inputMec.classList.remove('valid'); }
  } else { inputMec?.classList.remove('error', 'valid'); }
  
  const prix = prixActuels[pompe.carburant] || 0;
  const volumeCA = volElec > 0 ? volElec : volMec;
  ca = volumeCA * prix;
  
  document.getElementById(`vol_elec_${pumpId}`).textContent = finElec !== null ? fmtL(volElec) : '—';
  document.getElementById(`vol_mec_${pumpId}`).textContent = finMec !== null ? fmtL(volMec) : '—';
  document.getElementById(`vente_${pumpId}`).textContent = (finElec !== null || finMec !== null) ? fmtDH(ca) : '—';
  
  if (finElec !== null || finMec !== null || ecartStr !== '') {
    sessionData[pumpId] = { finElec, finMec, ecart: ecartStr, volElec, volMec, ca, prix, carburant: pompe.carburant, nom: pompe.nom, ligne: pompe.ligne, face: pompe.face };
  } else {
    delete sessionData[pumpId];
  }
  updateKPIs();
  updateCardStatus(pumpId);
};

function updateKPIs() {
  let totalVolElec = 0, totalVolMec = 0, totalCA = 0, nb = Object.keys(sessionData).length;
  Object.values(sessionData).forEach(d => { totalVolElec += d.volElec || 0; totalVolMec += d.volMec || 0; totalCA += d.ca || 0; });
  document.getElementById('kpiVolElec').textContent = fmtL(totalVolElec);
  document.getElementById('kpiVolMec').textContent = fmtL(totalVolMec);
  document.getElementById('kpiCA').textContent = fmtDH(totalCA);
  document.getElementById('kpiNb').textContent = `${nb} / 32`;
}

function updateCardStatus(pumpId) {
  const card = document.querySelector(`.pump-card:has(#fin_elec_${pumpId})`);
  const data = sessionData[pumpId];
  const hasData = data && (data.finElec !== null || data.finMec !== null || (data.ecart && data.ecart !== ''));
  if (card) {
    card.classList.remove('complete', 'missing');
    card.classList.add(hasData ? 'complete' : 'missing');
    const badge = card.querySelector('.status-badge');
    if (badge) { badge.textContent = hasData ? '✓ Saisi' : '⚠ Non saisi'; badge.className = `status-badge ${hasData ? 'complete' : 'missing'}`; }
  }
}

// ENREGISTREMENT (ne bloque pas si des distributeurs sont vides)
window.saveCompleteReleve = async function() {
  const dateReleve = document.getElementById('releveDate')?.value;
  if (!dateReleve) { toast('Sélectionnez une date', true); return; }
  
  let lignes = [], newDebutElec = {}, newDebutMec = {};
  let totalVolElec = 0, totalVolMec = 0, totalCA = 0;
  let nbSaisis = 0;
  
  for (const p of DISTRIBUTEURS) {
    const data = sessionData[p.id];
    if (!data || (data.finElec === null && data.finMec === null && !data.ecart)) {
      // Distributeur non saisi - on garde les anciens index
      newDebutElec[p.id] = debutIndex.elec[p.id];
      newDebutMec[p.id] = debutIndex.mec[p.id];
      lignes.push({
        pompeId: p.id, nom: p.nom, carburant: p.carburant, ligne: p.ligne, face: p.face,
        debutElec: debutIndex.elec[p.id], debutMec: debutIndex.mec[p.id],
        finElec: null, finMec: null, volElec: 0, volMec: 0, ecart: '', ca: 0, prix: 0, saisie: false
      });
    } else {
      nbSaisis++;
      totalVolElec += data.volElec || 0;
      totalVolMec += data.volMec || 0;
      totalCA += data.ca || 0;
      lignes.push({
        pompeId: p.id, nom: p.nom, carburant: p.carburant, ligne: p.ligne, face: p.face,
        debutElec: debutIndex.elec[p.id], debutMec: debutIndex.mec[p.id],
        finElec: data.finElec, finMec: data.finMec,
        volElec: data.volElec, volMec: data.volMec,
        ecart: data.ecart, ca: data.ca, prix: data.prix, saisie: true
      });
      if (data.finElec !== null) newDebutElec[p.id] = data.finElec;
      else newDebutElec[p.id] = debutIndex.elec[p.id];
      if (data.finMec !== null) newDebutMec[p.id] = data.finMec;
      else newDebutMec[p.id] = debutIndex.mec[p.id];
    }
  }
  
  await addDoc(collection(db, "releves_journaliers"), {
    date: new Date(dateReleve).toISOString(),
    dateStr: dateReleve,
    totalVolElec, totalVolMec, totalCA,
    nbSaisis: nbSaisis,
    nbTotal: 32,
    details: lignes
  });
  
  debutIndex.elec = newDebutElec;
  debutIndex.mec = newDebutMec;
  await setDoc(doc(db, "config", "initialStocksV2"), { elec: debutIndex.elec, mec: debutIndex.mec });
  
  sessionData = {};
  buildPumpsUI();
  await loadHistory();
  toast(`✅ Enregistré ! ${nbSaisis}/32 saisis | Élec: ${fmtL(totalVolElec)} | CA: ${fmtDH(totalCA)}`);
};

