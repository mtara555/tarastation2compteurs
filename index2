};
let currentLang='fr';
function toggleLang(){
  currentLang = currentLang==='fr'?'ar':'fr';
  document.documentElement.lang = currentLang;
  document.getElementById('langBtn').textContent = currentLang==='fr'?'AR':'FR';
  document.querySelectorAll('[data-i18n]').forEach(el=>{el.textContent=i18n[currentLang][el.dataset.i18n]});
  toast(currentLang==='ar'?'تم التحويل للعربية':'Passé en Français');
