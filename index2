<script>
// Validation FIN < DEBUT
document.addEventListener('input', e=>{
  if(e.target.id && (e.target.id.startsWith('finElec')||e.target.id.startsWith('finMec'))){
    const pid = e.target.dataset.pid;
    const type = e.target.id.includes('Elec')?'elec':'mec';
    const debut = debutIndex[type][pid]||0;
    const fin = parseFloat(e.target.value)||0;
    if(fin < debut && fin!==0){
      e.target.classList.add('error'); e.target.classList.remove('valid');
      toast('⚠️ FIN < DÉBUT !','err');
    } else { e.target.classList.remove('error'); e.target.classList.add('valid'); }
  }
});
</script>


